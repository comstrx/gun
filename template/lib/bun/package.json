{
    "name": "@user/name",
    "description": "this is demo library",

    "type": "module",
    "version": "0.1.0",
    "license": "(MIT OR Apache-2.0)",

    "sideEffects": false,
    "files": ["dist"],

    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",

    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build": "tsup",
        "test": "bun test",
        "typecheck": "bunx tsc -p tsconfig.json --noEmit",
        "prepublishOnly": "bun run test && bun run typecheck && bun run build"
    },
    "devDependencies": {
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "@types/bun": "latest"
    },
    "publishConfig": {
        "access": "public"
    }
}

{
    "name": "user/demo",
    "version": "0.1.0",
    "description": "this is demo library",
    "type": "library",
    "license": "(MIT OR Apache-2.0)",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "User\\Demo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "User\\Demo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

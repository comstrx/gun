{
    "name": "user/workspace",
    "version": "0.1.0",
    "description": "PHP workspace starter kit",
    "type": "metapackage",
    "license": "(MIT OR Apache-2.0)",
    "require": {
        "php": ">=8.3",
        "user/demo": "^0.1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "libs/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
